    <pre class="text-[0.25rem] text-nvim-blue">
             @@@@@@@@@@@@@@@@@@@@             
             @@@@@@@@@@@@@@@@@@@@             
            @@@@@@@@@@@@@@@@@@@@@@            
           @@@@@@@@@@@@@@@@@@@@@@@@           
          @@@@@@@@@@@@@@@@@@@@@@@@@           
          @@@@@@@@@@@@@@@@@@@@@@@@@@          
         @@@@@@@@@@@@@@@@@@@@@@@@@@@@         
         @@@@@@@@@@@@@@@@@@@@@@@@@@@@         
        @@@@@@@@@@@@@   @@@@@@@@@@@@@@        
       @@@@@@@@@@@@@@    @@@@@@@@@@@@@@       
      @@@@@@@@@@@@@@      @@@@@@@@@@@@@@      
      @@@@@@@@@@@@@@      @@@@@@@@@@@@@@      
     @@@@@@@@@@@@@@        @@@@@@@@@@@@@@     
    @@@@@@@@@@@@@@@        @@@@@@@@@@@@@@@    
    @@@@@@@@@@@@@@          @@@@@@@@@@@@@@    
   @@@@@@@@@@@@@@            @@@@@@@@@@@@@@   
  @@@@@@@@@@@@@@@            @@@@@@@@@@@@@@@  
  @@@@@@@@@@@@@@              @@@@@@@@@@@@@@  
 @@@@@@@@@                          @@@@@@@@@ 
@@@                                        @@@
            @                                 
            @@@                 @@            
